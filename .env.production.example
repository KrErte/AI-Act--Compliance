# ===========================================
# AIAudit Production Environment Variables
# ===========================================

# Database
POSTGRES_DB=aiaudit
POSTGRES_USER=aiaudit
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# Spring
SPRING_PROFILES_ACTIVE=prod

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_STRING_HERE
JWT_ACCESS_TOKEN_EXPIRY=900000
JWT_REFRESH_TOKEN_EXPIRY=604800000

# Email (Resend)
RESEND_API_KEY=re_your_production_api_key
MAIL_FROM=noreply@aiaudit.eu

# Domain
SITE_ADDRESS=aiaudit.eu
APP_FRONTEND_URL=https://aiaudit.eu

# LemonSqueezy (Payments)
LEMONSQUEEZY_API_KEY=your_production_api_key
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_secret
LEMONSQUEEZY_STORE_ID=your_store_id

# Claude API (AI Document Generation)
CLAUDE_API_KEY=sk-ant-your-production-key
CLAUDE_MODEL=claude-sonnet-4-20250514
